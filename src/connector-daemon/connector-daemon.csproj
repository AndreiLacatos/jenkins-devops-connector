    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>connector_daemon</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Update="Endpoints\Jobs\JobEvent.Model.cs">
      <DependentUpon>JobEvent.POST.cs</DependentUpon>
    </Compile>
    <Compile Update="Endpoints\Jobs\JobEvent.Validator.cs">
      <DependentUpon>JobEvent.POST.cs</DependentUpon>
    </Compile>
    <Compile Update="Endpoints\Jobs\JobEvent.Mapper.cs">
